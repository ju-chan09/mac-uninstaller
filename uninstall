def do_brew_uninstall(token: str) -> bool:
    console.rule("[bold bright_green]Uninstalling via Homebrew[/]", style="bright_green")
    console.print()
    result: List[subprocess.CompletedProcess] = []
    with Progress(SpinnerColumn(style="bright_green"), TextColumn("[bright_green]{task.description}"),
                  console=console, transient=True) as prog:
        task = prog.add_task(f"brew uninstall --cask {token}…")
        r = subprocess.run(
            ["brew", "uninstall", "--cask", "--force", token],
            capture_output=True, text=True, timeout=300,
        )
        result.append(r)
        prog.update(task, description=f"brew cleanup {token}…")
        subprocess.run(["brew", "cleanup", token], capture_output=True, text=True, timeout=60)

    r = result[0]
    if r.returncode == 0:
        console.print(f"  [bold bright_green]✓[/]  Homebrew uninstalled [bold]{token}[/]")
        console.print()
        return True
    err = (r.stderr + r.stdout).strip()
    console.print(f"  [yellow]⚠[/]  brew uninstall failed: [dim]{err[:200]}[/]")
    console.print()
    return False


# ── running app detection ────────────────────────────────────────────────────

def _pid_exists(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True  # exists but not ours to signal freely

def get_running_pids(app_path: Path) -> List[int]:
    """Return PIDs of processes running from within this app bundle."""
    pids: set = set()
    my_pid = os.getpid()

    try:
        r = subprocess.run(["pgrep", "-f", str(app_path)], capture_output=True, text=True, timeout=5)
        if r.returncode == 0:
            for p in r.stdout.strip().split():
                if p.isdigit() and int(p) != my_pid:
                    pids.add(int(p))
    except Exception:
        pass

    return sorted(pids)

def quit_app(app_name: str, pids: List[int]):
    with Progress(SpinnerColumn(style="yellow"), TextColumn("[yellow]{task.description}"),
                  console=console, transient=True) as prog:
        prog.add_task(f"Quitting {app_name}…")
        for pid in pids:
            try:
                os.kill(pid, signal.SIGTERM)
            except Exception:
                pass
        time.sleep(1.5)
        alive = [p for p in pids if _pid_exists(p)]
        for pid in alive:
            try:
                os.kill(pid, signal.SIGKILL)
            except Exception:
                pass

    alive = [p for p in pids if _pid_exists(p)]
    if alive:
        console.print(f"  [yellow]⚠[/]  Could not fully quit [bold]{app_name}[/] — proceeding anyway")
    else:
        console.print(f"  [green]✓[/]  [bold]{app_name}[/] quit")
    console.print()


# ── main run ──────────────────────────────────────────────────────────────────

def run(app_path: Path, preview: bool = False):
    app_name = app_path.stem
    bid = get_bundle_id(app_path)

    with Progress(SpinnerColumn(style="cyan"), TextColumn("[cyan]{task.description}"),
                  console=console, transient=True) as prog:
        prog.add_task("Scanning…")
        leftovers = scan(app_name, bid)
        cask_token = find_brew_cask(app_name)

    if cask_token:
        leftovers = scan_brew_cask(cask_token) + leftovers

    header = f"[bold green]✓[/]  [bold]{app_name}[/]"
    if bid:
        header += f"  [dim]{bid}[/]"
    if cask_token:
        header += f"  [bright_green]· homebrew cask[/]"
    console.print(header)
    console.print()

    all_items = [(app_path, "App Bundle")] + leftovers
    total_size = render_table(all_items)
    count = len(all_items)

    console.print()
    console.print(
        f"  [bold white]{count}[/] item{'s' if count!=1 else ''}  ·  "
        f"[bold white]{len(leftovers)}[/] leftover{'s' if len(leftovers)!=1 else ''}  ·  "
        f"[bold green]{fmt_size(total_size)}[/]"
    )
    console.print()

    if preview:
        if cask_token:
            console.print(f"  [dim]Homebrew cask detected: [bold]{cask_token}[/] — would uninstall via brew[/]")
        console.print("  [dim]Preview — no files removed.[/]")
        console.print()
        return

    pids = get_running_pids(app_path)
    if pids:
        pid_str = ", ".join(str(p) for p in pids[:3])
        suffix = "…" if len(pids) > 3 else ""
        console.print(
            f"  [yellow]⚠[/]  [bold]{app_name}[/] is currently running  [dim](PID {pid_str}{suffix})[/]"
        )
        console.print(f"  [dim]Quit before uninstalling?  [bold]Y[/] / [bold]N[/][/]  ", end="")
        console.file.flush()
        key = read_key()
        console.print()
        console.print()
        if key == "Y":
            quit_app(app_name, pids)

    console.rule(style="bright_black")
    console.print()
    if cask_token:
        console.print("  [dim]↑ ↓ move   ↵ confirm   B brew   T trash   D delete   N cancel[/]")
    else:
        console.print("  [dim]↑ ↓ move   ↵ confirm   T trash   D delete   N cancel[/]")
    console.print()

    choice = action_menu(has_brew=bool(cask_token))

    if choice == "brew":
        do_brew_uninstall(cask_token)
        with Progress(SpinnerColumn(style="cyan"), TextColumn("[cyan]{task.description}"),
                      console=console, transient=True) as prog:
            prog.add_task("Scanning for remaining files…")
            remaining_leftovers = scan(app_name, bid)
        remaining_leftovers = [(rp, c) for rp, c in remaining_leftovers if rp.exists()]
        remaining_app = [(app_path, "App Bundle")] if app_path.exists() else []
        remaining = remaining_app + remaining_leftovers
        if remaining:
            r_total = render_table(remaining)
            r_count = len(remaining)
            console.print()
            console.print(
                f"  [bold white]{r_count}[/] remaining item{'s' if r_count!=1 else ''}  ·  "
                f"[bold green]{fmt_size(r_total)}[/]"
            )
            console.print()
            console.rule(style="bright_black")
            console.print()
            console.print("  [dim]↑ ↓ move   ↵ confirm   T trash   D delete   N skip[/]")
            console.print()
            choice2 = action_menu(has_brew=False)
            if choice2 == "trash":
                do_trash(remaining, r_total)
            elif choice2 == "delete":
                do_delete(remaining, r_count, r_total)
            else:
                console.print("  [dim]Skipped.[/]")
                console.print()
        else:
            console.print("  [bold green]✓[/]  No leftover files — completely clean!")
            console.print()

    elif choice == "trash":
        do_trash(all_items, total_size)
    elif choice == "delete":
        do_delete(all_items, count, total_size)
    else:
        console.print("  [dim]Cancelled.[/]")
        console.print()



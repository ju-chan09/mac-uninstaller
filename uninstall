# ── formatting ────────────────────────────────────────────────────────────────

def fmt_size(n: int) -> str:
    for u in ("B", "KB", "MB", "GB", "TB"):
        if n < 1024:
            return f"{n:.1f} {u}"
        n /= 1024
    return f"{n:.1f} PB"

def path_size(p: Path) -> int:
    try:
        if p.is_symlink():
            return 0
        if p.is_file():
            return p.stat().st_size
        total = 0
        for e in p.rglob("*"):
            try:
                if e.is_file() and not e.is_symlink():
                    total += e.stat().st_size
            except (OSError, PermissionError):
                pass
        return total
    except (OSError, PermissionError):
        return 0

def short_path(p: Path) -> str:
    s = str(p)
    return ("~" + s[len(str(HOME)):]) if s.startswith(str(HOME)) else s


# ── app discovery ─────────────────────────────────────────────────────────────

USER_APP_DIRS = [
    Path("/Applications"),
    HOME / "Applications",
    Path("/Applications/Utilities"),
]

SYSTEM_APP_DIRS = [
    Path("/System/Applications"),
    Path("/System/Applications/Utilities"),
]

ALL_APP_DIRS = USER_APP_DIRS + SYSTEM_APP_DIRS

def is_system_app(path: Path) -> bool:
    return str(path).startswith("/System/")

def _is_apple_app(app: Path) -> bool:
    """True if the bundle ID starts with com.apple. — built-in Apple apps."""
    try:
        with open(app / "Contents" / "Info.plist", "rb") as f:
            bid = plistlib.load(f).get("CFBundleIdentifier", "")
        return isinstance(bid, str) and bid.startswith("com.apple.")
    except Exception:
        return False

def list_apps() -> List[Path]:
    """User-installed apps only — system apps excluded."""
    apps, seen = [], set()
    for d in USER_APP_DIRS:
        if not d.exists():
            continue
        for app in sorted(d.iterdir(), key=lambda p: p.stem.lower()):
            if app.suffix == ".app" and str(app) not in seen:
                seen.add(str(app))
                apps.append(app)
    return sorted(apps, key=lambda p: p.stem.lower())

def find_app(name: str) -> Optional[Path]:
    """Search all dirs including system (caller checks is_system_app)."""
    name = name.rstrip("/")
    p = Path(name)
    if p.exists() and p.suffix == ".app":
        return p
    stem = (p.stem if p.suffix == ".app" else name).lower()
    for d in ALL_APP_DIRS:
        if not d.exists():
            continue
        for app in d.iterdir():
            if app.suffix == ".app" and app.stem.lower() == stem:
                return app
    return None

def suggest_app(name: str) -> Optional[Path]:
    """Return the closest matching user app for a mistyped name."""
    apps = list_apps()
    if not apps:
        return None
    stems = {a.stem.lower(): a for a in apps}
    matches = difflib.get_close_matches(name.lower(), stems.keys(), n=1, cutoff=0.5)
    return stems[matches[0]] if matches else None

def get_bundle_id(app: Path) -> Optional[str]:
    try:
        r = subprocess.run(
            ["defaults", "read", str(app / "Contents" / "Info.plist"), "CFBundleIdentifier"],
            capture_output=True, text=True, timeout=5,
        )
        v = r.stdout.strip()
        return v or None
    except Exception:
        return None


# ── homebrew cask detection ───────────────────────────────────────────────────

CASKROOM_DIRS = [
    Path("/opt/homebrew/Caskroom"),   # Apple Silicon
    Path("/usr/local/Caskroom"),      # Intel
    HOME / "Library/Caskroom",
]

def _norm_cask(s: str) -> str:
    return s.lower().replace("-", "").replace(" ", "").replace("_", "")

def find_brew_cask(app_name: str) -> Optional[str]:
    """Return the brew cask token if this app is managed by Homebrew, else None."""
    if not shutil.which("brew"):
        return None
    norm = _norm_cask(app_name)
    # Fast path: Caskroom directories don't need a subprocess
    for caskroom in CASKROOM_DIRS:
        if not caskroom.exists():
            continue
        try:
            for entry in caskroom.iterdir():
                if _norm_cask(entry.name) == norm:
                    return entry.name
        except OSError:
            pass
    # Fallback: ask brew for installed casks
    try:
        r = subprocess.run(["brew", "list", "--cask"], capture_output=True, text=True, timeout=15)
        if r.returncode != 0:
            return None
        casks = r.stdout.strip().split()
        for cask in casks:
            if _norm_cask(cask) == norm:
                return cask
        for cask in casks:
            nc = _norm_cask(cask)
            if norm in nc or nc in norm:
                return cask
    except Exception:
        pass
    return None

def scan_brew_cask(token: str) -> List[Tuple[Path, str]]:
    """Return Caskroom directory for this token if it exists."""
    for caskroom in CASKROOM_DIRS:
        d = caskroom / token
        if d.exists():
            return [(d, "Homebrew Caskroom")]
    return []



def do_trash(all_items: List[Tuple[Path, str]], total_size: int):
    console.rule("[bold]Moving to Trash[/]", style="bright_black")
    console.print()
    ok = 0
    first_failures: List[Tuple[Path, str]] = []

    with Progress(SpinnerColumn(style="green"), TextColumn("[green]{task.description}"),
                  console=console, transient=True) as prog:
        task = prog.add_task("", total=len(all_items))
        for path, _ in all_items:
            prog.update(task, description=f"Trashing [dim]{path.name}[/]…")
            success, err = move_to_trash(path)
            if success:
                ok += 1
            else:
                first_failures.append((path, err))
            prog.advance(task)

    final_failures: List[Tuple[str, str]] = []
    first_failures = [(p, e) for p, e in first_failures if p.exists()]
    container_fails = [(p, e) for p, e in first_failures if _is_container_path(p)]
    admin_retryable  = [(p, e) for p, e in first_failures if not _is_container_path(p)]


def scan(app_name: str, bid: Optional[str]) -> List[Tuple[Path, str]]:
    hits: List[Tuple[Path, str]] = []
    seen: set = set()

    def add(path: Path, cat: str):
        key = str(path.resolve() if not path.is_symlink() else path)
        if key not in seen and path.exists():
            seen.add(key)
            hits.append((path, cat))

    bid_parts = bid.split(".") if bid else []
    short = bid_parts[-1] if bid_parts else app_name.split()[-1]
    names = list({app_name, short} - {""})

    def glob_dir(base: Path, cat: str, *pats: str):
        if not base.exists():
            return
        for pat in pats:
            if not pat:
                continue
            if (base / pat).exists():
                add(base / pat, cat)
            for m in base.glob(f"{pat}*"):
                add(m, cat)

    def glob_plist(base: Path, cat: str, *pats: str):
        if not base.exists():
            return
        for pat in pats:
            if not pat:
                continue
            for m in base.glob(f"{pat}*.plist"):
                add(m, cat)
            for m in base.glob(f"*{pat}*.plist"):
                add(m, cat)

    # ── Application Support ───────────────────────────────────────────────────
    glob_dir(HOME / "Library/Application Support",   "App Support",          *names, *([ bid] if bid else []))
    glob_dir(Path("/Library/Application Support"),   "App Support (system)", *names, *([bid] if bid else []))

    # ── Application Scripts ───────────────────────────────────────────────────
    if bid:
        glob_dir(HOME / "Library/Application Scripts", "App Scripts", bid)

    # ── Caches ────────────────────────────────────────────────────────────────
    glob_dir(HOME / "Library/Caches",      "Cache",          *names, *([bid] if bid else []))
    glob_dir(Path("/Library/Caches"),      "Cache (system)", *names, *([bid] if bid else []))

    # ── Logs ──────────────────────────────────────────────────────────────────
    glob_dir(HOME / "Library/Logs",  "Logs", *names, *([bid] if bid else []))
    glob_dir(Path("/Library/Logs"),  "Logs", *names, *([bid] if bid else []))

    # ── Crash reports ─────────────────────────────────────────────────────────
    for cd in [HOME / "Library/Logs/DiagnosticReports",
               Path("/Library/Logs/DiagnosticReports")]:
        if cd.exists():
            for n in names:
                for m in cd.glob(f"{n}*"):
                    add(m, "Crash Reports")

    # ── Preferences ───────────────────────────────────────────────────────────
    glob_plist(HOME / "Library/Preferences",          "Preferences",          *([bid] if bid else []), *names)
    glob_plist(HOME / "Library/Preferences/ByHost",   "Preferences/ByHost",   *([bid] if bid else []))
    glob_plist(Path("/Library/Preferences"),           "Preferences (system)", *([bid] if bid else []))

    # ── Containers ────────────────────────────────────────────────────────────
    if bid:
        glob_dir(HOME / "Library/Containers",        "Container",        bid)
        glob_dir(HOME / "Library/Daemon Containers", "Daemon Container", bid)

    # ── Group Containers ──────────────────────────────────────────────────────
    gc = HOME / "Library/Group Containers"
    if gc.exists() and bid:
        bl, sl = bid.lower(), short.lower()
        for m in gc.iterdir():
            nl = m.name.lower()
            if bl in nl or sl in nl:
                add(m, "Group Container")

    # ── Saved Application State ───────────────────────────────────────────────
    if bid:
        add(HOME / "Library/Saved Application State" / f"{bid}.savedState", "Saved State")

    # ── WebKit / HTTP / Cookies ───────────────────────────────────────────────
    if bid:
        glob_dir(HOME / "Library/WebKit",       "WebKit",       bid)
        glob_dir(HOME / "Library/HTTPStorages", "HTTP Storage", bid)
        add(HOME / "Library/Cookies" / f"{bid}.binarycookies", "Cookies")

    # ── Launch Agents / Daemons ───────────────────────────────────────────────
    if bid:
        for la in [HOME / "Library/LaunchAgents", Path("/Library/LaunchAgents")]:
            cat = "Launch Agent" if str(la).startswith(str(HOME)) else "Launch Agent (system)"
            if la.exists():
                for m in la.glob(f"{bid}*.plist"):
                    add(m, cat)
        ld = Path("/Library/LaunchDaemons")
        if ld.exists():
            for m in ld.glob(f"{bid}*.plist"):
                add(m, "Launch Daemon")

    # ── Privileged Helper Tools ───────────────────────────────────────────────
    pht = Path("/Library/PrivilegedHelperTools")
    if pht.exists() and bid:
        for m in pht.glob(f"{bid}*"):
            add(m, "Helper Tool")

    # ── Kernel Extensions ─────────────────────────────────────────────────────
    for ke in [Path("/Library/Extensions"), Path("/System/Library/Extensions")]:
        if ke.exists():
            for n in names:
                for m in ke.glob(f"{n}*.kext"):
                    add(m, "Kernel Extension")
            if bid:
                for m in ke.glob(f"{bid}*.kext"):
                    add(m, "Kernel Extension")

    # ── Preference Panes ──────────────────────────────────────────────────────
    for pp in [HOME / "Library/PreferencePanes", Path("/Library/PreferencePanes")]:
        if pp.exists():
            for n in names:
                for m in pp.glob(f"{n}*.prefPane"):
                    add(m, "PreferencePane")

    # ── Screen Savers ─────────────────────────────────────────────────────────
    for ss in [HOME / "Library/Screen Savers", Path("/Library/Screen Savers")]:
        if ss.exists():
            for n in names:
                for m in ss.glob(f"{n}*.saver"):
                    add(m, "Screen Saver")

    # ── Audio Plug-ins (VST/VST3/AU/CLAP/AAX) ────────────────────────────────
    audio_dirs = [
        HOME / "Library/Audio/Plug-Ins/Components",
        HOME / "Library/Audio/Plug-Ins/VST",
        HOME / "Library/Audio/Plug-Ins/VST3",
        HOME / "Library/Audio/Plug-Ins/CLAP",
        Path("/Library/Audio/Plug-Ins/Components"),
        Path("/Library/Audio/Plug-Ins/VST"),
        Path("/Library/Audio/Plug-Ins/VST3"),
        Path("/Library/Audio/Plug-Ins/CLAP"),
    ]
    audio_exts = ("*.component", "*.vst", "*.vst3", "*.clap", "*.aaxplugin")
    for ad in audio_dirs:
        if not ad.exists():
            continue
        for n in names:
            for ext in audio_exts:
                for m in ad.glob(f"{n}{ext}"):
                    add(m, "Audio Plugin")

    # ── QuickLook Generators ──────────────────────────────────────────────────
    for ql in [HOME / "Library/QuickLook", Path("/Library/QuickLook")]:
        if ql.exists():
            for n in names:
                for m in ql.glob(f"{n}*.qlgenerator"):
                    add(m, "QuickLook")

    # ── Spotlight Importers ───────────────────────────────────────────────────
    for sp in [HOME / "Library/Spotlight", Path("/Library/Spotlight")]:
        if sp.exists():
            for n in names:
                for m in sp.glob(f"{n}*.mdimporter"):
                    add(m, "Spotlight")

    # ── Internet Plug-ins ─────────────────────────────────────────────────────
    for ip in [HOME / "Library/Internet Plug-Ins", Path("/Library/Internet Plug-Ins")]:
        if ip.exists():
            for n in names:
                for m in ip.glob(f"{n}*"):
                    add(m, "Internet Plug-In")

    # ── Services ──────────────────────────────────────────────────────────────
    for sv in [HOME / "Library/Services", Path("/Library/Services")]:
        if sv.exists():
            for n in names:
                for m in sv.glob(f"{n}*"):
                    add(m, "Services")

    # ── Automator Actions ─────────────────────────────────────────────────────
    for am in [HOME / "Library/Automator", Path("/Library/Automator")]:
        if am.exists():
            for n in names:
                for m in am.glob(f"{n}*.action"):
                    add(m, "Automator")

    # ── Input Methods ─────────────────────────────────────────────────────────
    im = HOME / "Library/Input Methods"
    if im.exists():
        for n in names:
            for m in im.glob(f"{n}*.app"):
                add(m, "Input Method")

    # ── Color Pickers ─────────────────────────────────────────────────────────
    for cp in [HOME / "Library/ColorPickers", Path("/Library/ColorPickers")]:
        if cp.exists():
            for n in names:
                for m in cp.glob(f"{n}*.colorPicker"):
                    add(m, "Color Picker")

    # ── XDG config (~/.config) ────────────────────────────────────────────────
    config = HOME / ".config"
    if config.exists():
        for n in names:
            for candidate in [config / n, config / n.lower()]:
                if candidate.exists():
                    add(candidate, "XDG Config")

    # ── Package Receipts ──────────────────────────────────────────────────────
    receipts = Path("/private/var/db/receipts")
    if receipts.exists() and bid:
        for m in receipts.glob(f"{bid}*"):
            add(m, "Receipts")

    return hits


# ── table renderer ────────────────────────────────────────────────────────────

def render_table(all_items: List[Tuple[Path, str]]) -> int:
    tbl = Table(
        box=box.ROUNDED,
        border_style="bright_black",
        header_style="bold on grey11",
        padding=(0, 1),
        expand=True,
        show_lines=False,
    )
    tbl.add_column("#", width=4, justify="right", style="dim")
    tbl.add_column("Category", min_width=20)
    tbl.add_column("Path")
    tbl.add_column("Size", justify="right", min_width=9)

    total = 0
    for i, (path, cat) in enumerate(all_items, 1):
        sz = path_size(path)
        total += sz
        color = CATEGORY_STYLE.get(cat, "white")
        size_style = "bold green" if sz > 50*1024*1024 else ("green" if sz > 0 else "dim")
        tbl.add_row(
            str(i),
            Text(cat, style=color),
            Text(short_path(path), overflow="fold"),
            Text(fmt_size(sz), style=size_style),
        )

    console.print(tbl)
    return total


# ── file operations ───────────────────────────────────────────────────────────

def _requires_admin(path: Path) -> bool:
    s = str(path)
    return s.startswith("/Library/") or s.startswith("/private/var/") or s.startswith("/usr/")

def _is_protected_bundle(path: Path) -> bool:
    """True for .app bundles outside the user's home — macOS App Management applies."""
    return path.suffix == ".app" and not str(path).startswith(str(HOME))

def _is_container_path(path: Path) -> bool:
    """True for App Store sandbox containers — protected by FDA, not admin."""
    s = str(path)
    return s.startswith(str(HOME / "Library/Containers/")) or \
           s.startswith(str(HOME / "Library/Group Containers/")) or \
           s.startswith(str(HOME / "Library/Daemon Containers/"))

def _terminal_name() -> str:
    t = os.environ.get("TERM_PROGRAM", "").lower()
    for name, label in [("ghostty", "Ghostty"), ("iterm", "iTerm2"),
                         ("apple_terminal", "Terminal"), ("kitty", "kitty"),
                         ("warp", "Warp"), ("hyper", "Hyper")]:
        if name in t:
            return label
    return "your terminal"

def _osascript_rm_batch(paths: List[Path]) -> List[Tuple[bool, str]]:
    """Delete multiple paths via one admin-auth dialog."""
    cmds = "; ".join(f"rm -rf {shlex.quote(str(p))}" for p in paths)
    r = subprocess.run(
        ["osascript", "-e", f'do shell script "{cmds}" with administrator privileges'],
        capture_output=True, timeout=120,
    )
    err = r.stderr.decode(errors="replace").strip() or "admin delete failed"
    return [(not p.exists(), "" if not p.exists() else err) for p in paths]

def move_to_trash(path: Path) -> Tuple[bool, str]:
    """Move to ~/.Trash directly — no Finder automation."""
    # Protected bundles in /Applications need admin mv; skip to avoid the
    # "Terminal was prevented from modifying apps" notification.
    if _is_protected_bundle(path):
        return False, "app bundle in /Applications requires admin access"
    try:
        dest = HOME / ".Trash" / path.name
        n = 1
        while dest.exists():
            dest = HOME / ".Trash" / f"{path.stem} ({n}){path.suffix}"
            n += 1
        shutil.move(str(path), str(dest))
        return True, ""
    except Exception as e:
        return False, str(e)

def _trash_admin_batch(paths: List[Path]) -> List[Tuple[bool, str]]:
    """Move multiple paths to Trash via one admin-auth dialog."""
    trash = shlex.quote(str(HOME / ".Trash"))
    cmds = "; ".join(f"mv {shlex.quote(str(p))} {trash}/" for p in paths)
    r = subprocess.run(
        ["osascript", "-e",
         f'do shell script "{cmds}" with administrator privileges'],
        capture_output=True, timeout=60,
    )
    err = r.stderr.decode(errors="replace").strip() or "admin move failed"
    return [(not p.exists(), "" if not p.exists() else err) for p in paths]

def delete_permanent(path: Path) -> Tuple[bool, str]:
    """Delete without admin. Protected .app bundles skip direct delete to avoid
    triggering the macOS App Management notification."""
    if _is_protected_bundle(path):
        return False, "App bundle in /Applications requires admin access"
    try:
        if path.is_dir() and not path.is_symlink():
            shutil.rmtree(str(path))
        else:
            path.unlink()
        return True, ""
    except Exception as e:
        return False, str(e)


# ── keyboard input ────────────────────────────────────────────────────────────

def _open_tty():
    try:
        return open("/dev/tty", "rb", buffering=0)
    except OSError:
        console.print()
        console.print("[red]✗[/]  No interactive terminal — run [bold]uninstall[/] directly in Ghostty, Terminal, or iTerm2.")
        console.print()
        sys.exit(1)

def read_key() -> str:
    with _open_tty() as f:
        fd = f.fileno()
        old = termios.tcgetattr(fd)
        try:
            tty.setraw(fd)
            ch = f.read(1)
            if ch == b"\x1b":
                if _select.select([f], [], [], 0.05)[0]:
                    rest = f.read(2)
                    if rest == b"[A": return "UP"
                    if rest == b"[B": return "DOWN"
                    if rest == b"[5": f.read(1); return "PGUP"
                    if rest == b"[6": f.read(1); return "PGDN"
                return "ESC"
            if ch in (b"\r", b"\n"): return "ENTER"
            if ch == b"\x03":        return "CTRL_C"
            if ch == b"\x7f":        return "BACKSPACE"
            decoded = ch.decode("utf-8", errors="replace")
            return decoded.upper()
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)


# ── terminal helpers ──────────────────────────────────────────────────────────

def term_height() -> int:
    try:
        return os.get_terminal_size().lines
    except OSError:
        return 24

def term_width() -> int:
    try:
        return os.get_terminal_size().columns
    except OSError:
        return 80

def clear_lines(n: int):
    if n > 0:
        console.file.flush()
        sys.stdout.write(f"\x1b[{n}F\x1b[J")
        sys.stdout.flush()


# ── app browser ───────────────────────────────────────────────────────────────

def browser(preview: bool = False) -> Optional[Path]:
    all_apps = list_apps()
    if not preview:
        all_apps = [a for a in all_apps if not _is_apple_app(a)]
    if not all_apps:
        console.print("[red]✗[/]  No apps found.")
        return None

    query = ""
    filtered = all_apps[:]
    sel = 0
    offset = 0
    lines_drawn = 0

    def filter_apps(q: str) -> List[Path]:
        if not q:
            return all_apps[:]
        ql = q.lower()
        return [a for a in all_apps if ql in a.stem.lower()]

    def draw():
        nonlocal offset, lines_drawn
        rows = min(15, max(4, term_height() - 7))

        # Clamp selection into view
        if sel < offset:
            offset = sel
        elif sel >= offset + rows:
            offset = sel - rows + 1

        clear_lines(lines_drawn)
        drawn = 0
        w = term_width()

        # Search bar
        if query:
            console.print(f"  [dim]Search:[/] [bold white]{query}[/][blink]█[/]  [dim]{len(filtered)} result{'s' if len(filtered)!=1 else ''}[/]")
        else:
            console.print(f"  [dim]Type to search · ↑↓ navigate · ↵ select · Q quit[/]")
        drawn += 1

        console.print()
        drawn += 1

        # App rows
        visible = filtered[offset:offset + rows]
        for i, app in enumerate(visible):
            idx = offset + i
            is_sel = (idx == sel)
            parent = str(app.parent).replace(str(HOME), "~")
            name_col = app.stem

            if is_sel:
                # Pad to fill width for highlight bar feel
                pad = max(0, w - len(name_col) - len(parent) - 9)
                console.print(
                    f"  [bold white on grey15] ❯  {name_col}[/]"
                    f"[dim on grey15]{'':>{pad}}{parent} [/]"
                )
            else:
                console.print(f"     [white]{name_col}[/]  [dim]{parent}[/]")
            drawn += 1

        console.print()
        mode = "[dim]preview mode[/]" if preview else ""
        count_str = f"[dim]{len(all_apps)} apps[/]"
        console.print(f"  {count_str}  {mode}")
        drawn += 2

        lines_drawn = drawn

    draw()

    while True:
        key = read_key()

        if key in ("Q", "ESC", "CTRL_C"):
            clear_lines(lines_drawn)
            return None

        elif key == "ENTER":
            if filtered:
                clear_lines(lines_drawn)
                return filtered[sel]

        elif key == "UP":
            if filtered:
                sel = max(0, sel - 1)
                draw()

        elif key == "DOWN":
            if filtered:
                sel = min(len(filtered) - 1, sel + 1)
                draw()

        elif key == "PGUP":
            if filtered:
                rows = min(15, max(4, term_height() - 7))
                sel = max(0, sel - rows)
                draw()

        elif key == "PGDN":
            if filtered:
                rows = min(15, max(4, term_height() - 7))
                sel = min(len(filtered) - 1, sel + rows)
                draw()

        elif key == "BACKSPACE":
            if query:
                query = query[:-1]
                filtered = filter_apps(query)
                sel = 0
                offset = 0
                draw()

        elif len(key) == 1 and (key.isalpha() or key.isdigit() or key in " .-_"):
            query += key.lower()
            filtered = filter_apps(query)
            sel = 0
            offset = 0
            draw()


# ── action menu ───────────────────────────────────────────────────────────────

def action_menu(has_brew: bool = False) -> str:
    """Returns: 'brew' | 'trash' | 'delete' | 'cancel'"""
    items: List[Tuple[str, str, str, str]] = []
    if has_brew:
        items.append(("Uninstall via Homebrew", "removes cask + runs cleanup", "bright_green", "brew"))
    items.extend([
        ("Move to Trash",      "safer — recoverable from Finder", "green", "trash"),
        ("Delete permanently", "no undo",                        "red",   "delete"),
        ("Cancel",             "",                               "",      "cancel"),
    ])

    sel = 0

    def draw():
        for i, (label, desc, color, _) in enumerate(items):
            if i == sel:
                line = f"  [bold white]❯[/]  [bold {color}]{label}[/]"
                if desc:
                    line += f"   [dim]{desc}[/]"
            else:
                line = f"     [dim]{label}[/]"
            console.print(line)

    draw()
    while True:
        key = read_key()
        moved = False
        if key == "UP":
            sel = (sel - 1) % len(items); moved = True
        elif key == "DOWN":
            sel = (sel + 1) % len(items); moved = True
        elif key == "ENTER":
            break
        elif key == "B" and has_brew:
            sel = 0; break
        elif key == "T":
            sel = next(i for i, item in enumerate(items) if item[3] == "trash"); break
        elif key == "D":
            sel = next(i for i, item in enumerate(items) if item[3] == "delete"); break
        elif key in ("N", "ESC", "CTRL_C"):
            sel = next(i for i, item in enumerate(items) if item[3] == "cancel"); break
        else:
            continue
        if moved:
            clear_lines(len(items))
            draw()

    clear_lines(len(items))
    label, desc, color, action = items[sel]
    line = f"  [bold white]❯[/]  [bold {color}]{label}[/]"
    if desc:
        line += f"   [dim]{desc}[/]"
    console.print(line)
    console.print()
    return action



                ok += 1
            else:
                final_failures.append((short_path(path), err or err_by_path.get(path, "")))
    elif admin_retryable:
        final_failures = [(short_path(p), e) for p, e in admin_retryable]

    if container_fails:
        final_failures += [(short_path(p), e) for p, e in container_fails]

    msg = f"  [bold green]✓[/]  {ok} item{'s' if ok!=1 else ''} moved to Trash"
    if final_failures:
        msg += f"  [dim]· {len(final_failures)} failed[/]"

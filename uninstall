def main():
    args = sys.argv[1:]

    if args and args[0] in ("-h", "--help"):
        _usage()
        sys.exit(0)

    if args and args[0] in ("-v", "--version"):
        print(f"uninstall {__version__}")
        sys.exit(0)

    preview = False
    if args and args[0] == "-p":
        preview = True
        args = args[1:]

    signal.signal(signal.SIGINT,
                  lambda *_: (console.print("\n\n  [dim]Cancelled.[/]\n"), sys.exit(0)))

    # Header — shown once regardless of path
    console.print()
    console.print(Panel.fit(
        "[bold white]uninstall[/]  [dim]macOS app cleaner[/]"
        + ("  [dim italic]preview[/]" if preview else ""),
        border_style="bright_black",
        padding=(0, 2),
    ))
    console.print()

    if args:
        name = " ".join(args)
        app_path = find_app(name)

        if app_path and is_system_app(app_path):
            console.print(f"[yellow]⚠[/]  [bold]{app_path.stem}[/] is a macOS system app and cannot be uninstalled.")
            console.print()
            sys.exit(1)

        if app_path and not preview and _is_apple_app(app_path):
            console.print(f"[yellow]⚠[/]  [bold]{app_path.stem}[/] is a built-in Apple app and cannot be uninstalled.")
            console.print()
            sys.exit(1)

        if not app_path:
            console.print(f"[red]✗[/]  [bold]{name}[/] not found.")
            suggestion = suggest_app(name)
            if suggestion:
                console.print()
                console.print(f"  Did you mean [bold]{suggestion.stem}[/]?  [dim]Y / N[/]  ", end="")
                console.file.flush()
                key = read_key()
                console.print()
                console.print()
                if key == "Y":
                    run(suggestion, preview=preview)
                    return
            console.print()
            sys.exit(1)

        run(app_path, preview=preview)
    else:
        app_path = browser(preview=preview)
        if app_path:
            run(app_path, preview=preview)

if __name__ == "__main__":
    main()
